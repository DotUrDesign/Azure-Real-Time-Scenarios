{
	"name": "dataflow1",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DelimitedText8",
						"type": "DatasetReference"
					},
					"name": "source"
				}
			],
			"sinks": [],
			"transformations": [
				{
					"name": "derivedColumn"
				},
				{
					"name": "select"
				}
			],
			"scriptLines": [
				"source(output(",
				"          {1           Alice Johnson                                                                            75000                                   Engineering                                                 } as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source",
				"source derive(id = substring({1           Alice Johnson                                                                            75000                                   Engineering                                                 }, 0, 11),",
				"          name = substring({1           Alice Johnson                                                                            75000                                   Engineering                                                 }, 12, 89),",
				"          salary = substring({1           Alice Johnson                                                                            75000                                   Engineering                                                 }, 101, 40),",
				"          department = substring({1           Alice Johnson                                                                            75000                                   Engineering                                                 }, 141, 60)) ~> derivedColumn",
				"derivedColumn select(mapColumn(",
				"          id,",
				"          name,",
				"          salary,",
				"          department",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select"
			]
		}
	}
}